<?xml version="1.0" encoding="utf-8"?>
<!--
  BLOKD launcher foreground: geometric "B." monogram. White B with diagonal
  counter cuts, orange period. Sized and centered in the adaptive-icon safe
  zone so it reads bold and a circular launcher mask does not clip the period.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:scaleX="0.20"
        android:scaleY="0.20"
        android:translateX="-2.4"
        android:translateY="2.8">

        <!-- Stem -->
        <path
            android:fillColor="@color/ic_launcher_foreground"
            android:pathData="M166,112 H200 A16,16 0 0 1 216,128 V384 A16,16 0 0 1 200,400 H166 A16,16 0 0 1 150,384 V128 A16,16 0 0 1 166,112 Z" />
        <!-- Upper bowl -->
        <path
            android:fillColor="@color/ic_launcher_foreground"
            android:pathData="M188,112 H300 A74,74 0 0 1 300,260 H188 Z" />
        <!-- Lower bowl -->
        <path
            android:fillColor="@color/ic_launcher_foreground"
            android:pathData="M188,252 H300 A76,76 0 0 1 300,400 H188 Z" />

        <!-- Counters (diagonal cuts), punched through to the black plate -->
        <path
            android:fillColor="#FF000000"
            android:pathData="M212,152 H296 V218 L212,262 Z" />
        <path
            android:fillColor="#FF000000"
            android:pathData="M212,292 L296,250 V360 H212 Z" />

        <!-- Period -->
        <path
            android:fillColor="@color/brand_orange"
            android:pathData="M380,332 a28,28 0 1 0 0,56 a28,28 0 1 0 0,-56 Z" />
    </group>
</vector>
